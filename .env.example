# Slack
SLACK_BOT_TOKEN=replace-with-slack-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# AWS
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=123456789012

# DynamoDB
DYNAMODB_JOBS_TABLE=explain_jobs
DYNAMODB_USERS_TABLE=user_profiles
DYNAMODB_CHANNELS_TABLE=channel_contexts
DYNAMODB_FEEDBACK_TABLE=feedback

# SQS
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/explain-jobs.fifo

# Bedrock
BEDROCK_REGION=ap-northeast-1
BEDROCK_KB_ID=your-knowledge-base-id
BEDROCK_MODEL_HAIKU=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MODEL_SONNET=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_GUARDRAIL_ID=your-guardrail-id

# S3
S3_BUCKET_NAME=explain-bot-123456789012-ap-northeast-1

# MCP (将来対応)
# GITHUB_TOKEN=your-github-token
# GOOGLE_DRIVE_CREDENTIALS=path/to/credentials.json

# ログレベル
LOG_LEVEL=INFO
